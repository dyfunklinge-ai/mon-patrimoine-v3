<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024" width="1024" height="1024">
  <defs>
    <!-- Background gradient -->
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#07090f"/>
      <stop offset="100%" style="stop-color:#0d1220"/>
    </linearGradient>

    <!-- Cyan glow gradient -->
    <radialGradient id="cyanGlow" cx="38%" cy="30%" r="55%">
      <stop offset="0%" style="stop-color:#4af4e8;stop-opacity:0.18"/>
      <stop offset="100%" style="stop-color:#4af4e8;stop-opacity:0"/>
    </radialGradient>

    <!-- Violet glow gradient -->
    <radialGradient id="violetGlow" cx="72%" cy="75%" r="45%">
      <stop offset="0%" style="stop-color:#9b7af0;stop-opacity:0.14"/>
      <stop offset="100%" style="stop-color:#9b7af0;stop-opacity:0"/>
    </radialGradient>

    <!-- Diamond gradient -->
    <linearGradient id="diamondGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4af4e8"/>
      <stop offset="50%" style="stop-color:#00c8bd"/>
      <stop offset="100%" style="stop-color:#9b7af0"/>
    </linearGradient>

    <!-- Diamond shimmer -->
    <linearGradient id="shimmerGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ffffff;stop-opacity:0.25"/>
      <stop offset="40%" style="stop-color:#ffffff;stop-opacity:0.08"/>
      <stop offset="100%" style="stop-color:#ffffff;stop-opacity:0"/>
    </linearGradient>

    <!-- Bar gradient -->
    <linearGradient id="barGrad1" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#4af4e8"/>
      <stop offset="100%" style="stop-color:#00c8bd;stop-opacity:0.6"/>
    </linearGradient>
    <linearGradient id="barGrad2" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#9b7af0"/>
      <stop offset="100%" style="stop-color:#7c5de0;stop-opacity:0.6"/>
    </linearGradient>
    <linearGradient id="barGrad3" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#3ddc97"/>
      <stop offset="100%" style="stop-color:#27a76e;stop-opacity:0.6"/>
    </linearGradient>

    <!-- Rounded rect clip -->
    <clipPath id="roundClip">
      <rect width="1024" height="1024" rx="230" ry="230"/>
    </clipPath>

    <!-- Glow filters -->
    <filter id="cyanGlowFilter" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur in="SourceGraphic" stdDeviation="12" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="softGlow" x="-30%" y="-30%" width="160%" height="160%">
      <feGaussianBlur in="SourceGraphic" stdDeviation="6" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>

  <!-- Clipped background -->
  <g clip-path="url(#roundClip)">
    <!-- Base background -->
    <rect width="1024" height="1024" fill="url(#bgGrad)"/>

    <!-- Ambient glows -->
    <rect width="1024" height="1024" fill="url(#cyanGlow)"/>
    <rect width="1024" height="1024" fill="url(#violetGlow)"/>

    <!-- Subtle grid lines (top half only) -->
    <g opacity="0.04" stroke="#4af4e8" stroke-width="1">
      <line x1="0" y1="200" x2="1024" y2="200"/>
      <line x1="0" y1="340" x2="1024" y2="340"/>
      <line x1="0" y1="480" x2="1024" y2="480"/>
      <line x1="200" y1="0" x2="200" y2="520"/>
      <line x1="400" y1="0" x2="400" y2="520"/>
      <line x1="600" y1="0" x2="600" y2="520"/>
      <line x1="800" y1="0" x2="800" y2="520"/>
    </g>

    <!-- ◈ Diamond symbol — main hero -->
    <!-- Outer diamond ring -->
    <polygon points="512,180 720,388 512,596 304,388"
      fill="none" stroke="url(#diamondGrad)" stroke-width="3" opacity="0.25"/>
    <!-- Inner diamond ring -->
    <polygon points="512,240 660,388 512,536 364,388"
      fill="none" stroke="url(#diamondGrad)" stroke-width="2" opacity="0.15"/>

    <!-- Main ◈ diamond shape -->
    <!-- Left top facet -->
    <polygon points="512,220 640,388 512,388" fill="#4af4e8" opacity="0.18"/>
    <!-- Right top facet -->
    <polygon points="512,220 384,388 512,388" fill="#4af4e8" opacity="0.10"/>
    <!-- Left bottom facet -->
    <polygon points="512,556 640,388 512,388" fill="#9b7af0" opacity="0.22"/>
    <!-- Right bottom facet -->
    <polygon points="512,556 384,388 512,388" fill="#9b7af0" opacity="0.14"/>

    <!-- Diamond outline glow -->
    <polygon points="512,220 640,388 512,556 384,388"
      fill="none" stroke="url(#diamondGrad)" stroke-width="4.5"
      filter="url(#cyanGlowFilter)" opacity="0.9"/>
    <!-- Diamond outline crisp -->
    <polygon points="512,220 640,388 512,556 384,388"
      fill="none" stroke="url(#diamondGrad)" stroke-width="2.5" opacity="1"/>

    <!-- Center crosshair lines inside diamond -->
    <line x1="512" y1="270" x2="512" y2="508" stroke="url(#diamondGrad)" stroke-width="1.5" opacity="0.4"/>
    <line x1="408" y1="388" x2="616" y2="388" stroke="url(#diamondGrad)" stroke-width="1.5" opacity="0.4"/>

    <!-- Corner dots -->
    <circle cx="512" cy="220" r="5" fill="#4af4e8" filter="url(#softGlow)" opacity="0.9"/>
    <circle cx="640" cy="388" r="5" fill="#4af4e8" filter="url(#softGlow)" opacity="0.9"/>
    <circle cx="512" cy="556" r="5" fill="#9b7af0" filter="url(#softGlow)" opacity="0.9"/>
    <circle cx="384" cy="388" r="5" fill="#9b7af0" filter="url(#softGlow)" opacity="0.9"/>

    <!-- Mini chart bars — bottom section -->
    <!-- Bar 1 (green) -->
    <rect x="272" y="660" width="68" height="170" rx="10" fill="url(#barGrad3)" opacity="0.85"/>
    <rect x="272" y="660" width="68" height="8" rx="4" fill="#3ddc97" opacity="0.9"/>

    <!-- Bar 2 (cyan — tallest) -->
    <rect x="372" y="600" width="68" height="230" rx="10" fill="url(#barGrad1)" opacity="0.9"/>
    <rect x="372" y="600" width="68" height="8" rx="4" fill="#4af4e8" opacity="0.95"/>

    <!-- Bar 3 (violet) -->
    <rect x="472" y="640" width="68" height="190" rx="10" fill="url(#barGrad2)" opacity="0.85"/>
    <rect x="472" y="640" width="68" height="8" rx="4" fill="#9b7af0" opacity="0.9"/>

    <!-- Bar 4 (cyan lighter) -->
    <rect x="572" y="678" width="68" height="152" rx="10" fill="url(#barGrad1)" opacity="0.7"/>
    <rect x="572" y="678" width="68" height="8" rx="4" fill="#4af4e8" opacity="0.8"/>

    <!-- Bar 5 (green shorter) -->
    <rect x="672" y="704" width="68" height="126" rx="10" fill="url(#barGrad3)" opacity="0.65"/>
    <rect x="672" y="704" width="68" height="8" rx="4" fill="#3ddc97" opacity="0.7"/>

    <!-- Baseline -->
    <line x1="240" y1="834" x2="784" y2="834" stroke="rgba(255,255,255,0.06)" stroke-width="1.5"/>

    <!-- Trend line over bars -->
    <polyline points="306,680 406,618 506,657 606,695 706,722"
      fill="none" stroke="#4af4e8" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"
      filter="url(#cyanGlowFilter)" opacity="0.7"/>
    <!-- Trend dots -->
    <circle cx="306" cy="680" r="6" fill="#4af4e8" opacity="0.9"/>
    <circle cx="406" cy="618" r="6" fill="#4af4e8" opacity="0.9"/>
    <circle cx="506" cy="657" r="6" fill="#4af4e8" opacity="0.9"/>
    <circle cx="606" cy="695" r="6" fill="#4af4e8" opacity="0.9"/>
    <circle cx="706" cy="722" r="6" fill="#4af4e8" opacity="0.9"/>

    <!-- Top shimmer highlight on the whole icon -->
    <rect width="1024" height="400" fill="url(#shimmerGrad)" opacity="0.4"/>

    <!-- Subtle border glow inside -->
    <rect width="1024" height="1024" rx="230" ry="230"
      fill="none" stroke="rgba(74,244,232,0.15)" stroke-width="3"/>
  </g>
</svg>
